#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
# Copyright 2026 Weft Contributors

# /// script
# requires-python = ">=3.11"
# ///
"""SessionStart hook: orient a session inside a weft-managed repo.

Surfaces two things a static ``bd remember`` injection cannot:
  (a) weft's verb surface + vocabulary (entry skills, warp/weft/pick/shed), so a
      session knows the weft front doors independent of the beads plugin; and
  (b) DYNAMIC warp status — live `bd ready` pick count and the open/incomplete
      epics — computed at session start.

Stdlib-only by design, so the shebang is a bare ``python3`` (ubiquitous — no uv
prerequisite to invoke the hook at session start). The PEP 723 ``# /// script``
block above is kept so uv users can still ``uv run --script`` it; the test-suite
invokes it via ``sys.executable``. Always exits 0 — orientation must never block
or fail a session. A repo is weft-managed iff a ``.beads/`` warp is present (the
same signal as feature/onboard).
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from lib import warp  # noqa: E402

# bd is on the session's hot path at startup; cap each probe so a slow or wedged
# warp degrades to orientation-only instead of stalling the session. Two probes
# run back-to-back, so the worst case is 2×_BD_TIMEOUT_S — kept comfortably
# under the hooks.json `timeout: 10` outer kill (3s → 6s worst case, ~4s of
# headroom for interpreter startup + I/O). Overridable so the test-suite can
# drive the timeout path with a tiny budget instead of a real multi-second stall.
try:
    _BD_TIMEOUT_S = float(os.environ.get("WEFT_HOOK_BD_TIMEOUT_S", "3"))
except ValueError:
    _BD_TIMEOUT_S = 3.0

# When set, write a one-line reason to stderr each time a bd probe degrades, so
# an operator seeing orientation-only can tell "no warp" from "bd is wedged".
_DEBUG = bool(os.environ.get("WEFT_HOOK_DEBUG"))


def _debug(msg: str) -> None:
    if _DEBUG:
        print(f"session-start-weft-orient: {msg}", file=sys.stderr)


def _bd_json(args: list[str], cwd: str):
    """Run ``bd <args> --json`` and parse stdout, or return None on any failure
    (bd missing, non-zero exit, timeout, unparseable output)."""
    try:
        proc = subprocess.run(
            ["bd", *args, "--json"],
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=_BD_TIMEOUT_S,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        _debug(f"bd {' '.join(args)} failed to run: {exc!r}")
        return None
    if proc.returncode != 0 or not proc.stdout.strip():
        _debug(f"bd {' '.join(args)} exited {proc.returncode} (degrading)")
        return None
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError:
        _debug(f"bd {' '.join(args)} returned unparseable JSON (degrading)")
        return None


def _warp_lines(cwd: str) -> list[str]:
    ready = _bd_json(["ready"], cwd)
    ready_count = len(ready) if isinstance(ready, list) else None
    epic_status = _bd_json(["epic", "status"], cwd)
    if not isinstance(epic_status, list):
        epic_status = []
    return warp.format_warp_status(ready_count, epic_status)


def main() -> None:
    try:
        raw = sys.stdin.read()
        data = json.loads(raw) if raw.strip() else {}
    except (json.JSONDecodeError, OSError):
        sys.exit(0)

    cwd = data.get("cwd", os.getcwd())
    if not isinstance(cwd, str):  # hostile/garbled payload — Path(int) would raise
        cwd = os.getcwd()
    if not warp.is_weft_managed(cwd):
        sys.exit(0)

    context = warp.build_context(_warp_lines(cwd))
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "SessionStart",
                    "additionalContext": context,
                }
            }
        )
    )


if __name__ == "__main__":
    main()
