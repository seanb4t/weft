.task/

# worktrees / jj workspaces
.worktrees/
.weft-workspaces/

# Superpowers brainstorming artifacts
.superpowers/

# .weft/ holds local engine state; ship only the committed config.toml so a
# fresh clone has a verify gate out of the box (weft-bcq). Ignore the dir
# contents but re-include the tracked config (dir must stay listable for the
# negation to take effect — a bare `.weft/` would block it).
.weft/*
!.weft/config.toml

# Stray beads export in worktree root (belongs under .beads/ only)
/issues.jsonl

# Beads local state
.beads/metadata.json
.beads-credential-key

# Dolt database files (added by bd init)
.dolt/
*.db

# Claude Code local-scope agent memory (never committed)
.claude/agent-memory-local/

# Beads / Dolt files (added by bd init)
.beads/proxieddb/

# Python hook build artifacts (plugin/hooks/)
__pycache__/
*.pyc
.pytest_cache/
